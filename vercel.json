{
  "version": 2,
  "functions": {
    "server.ts": {
      "includeFiles": "hltb_bridge.py"
    }
  },
  "routes": [
    {
      "src": "/(api|auth)(.*)",
      "dest": "server.ts"
    },
    {
      "src": "/(.*)",
      "dest": "/$1",
      "check": true
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}