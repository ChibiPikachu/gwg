{
  "version": 2,
  "builds": [
    {
      "src": "api/hltb.py",
      "use": "@vercel/python"
    },
    {
      "src": "api/hltb-batch.py",
      "use": "@vercel/python"
    },
    {
      "src": "server.ts",
      "use": "@vercel/node"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "routes": [
    {
      "src": "/(api|auth)(.*)",
      "dest": "server.ts"
    },
    {
      "src": "/(.*)",
      "dest": "/$1",
      "check": true
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
  
}
