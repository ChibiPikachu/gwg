{
  "version": 2,
  "functions": {
    "api/server.ts": {
      "includeFiles": "hltb_bridge.py"
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/server.ts" },
    { "source": "/auth/:path*", "destination": "/api/server.ts" },
    { "source": "/assets/:path*", "destination": "/assets/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "cleanUrls": true
}
