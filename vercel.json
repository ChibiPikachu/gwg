{
  "version": 2,
  "functions": {
    "api/server.ts": {
      "memory": 1024,
      "maxDuration": 10,
      "includeFiles": "api/hltb_bridge.py"
    }
  },
  "routes": [
    { "src": "/(api|auth)(.*)", "dest": "/api/server.ts" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}