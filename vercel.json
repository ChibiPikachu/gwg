{
  "version": 2,
  "functions": {
    "api/server.ts": {
      "includeFiles": "hltb_bridge.py"
    }
  },
  "routes": [
    {
      "src": "/(api|auth)(.*)",
      "dest": "/api/server.ts"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}