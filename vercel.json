{
  "version": 2,
  "functions": {
    "api/server.ts": {
      "includeFiles": "hltb_bridge.py"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/server.ts" },
    { "source": "/auth/(.*)", "destination": "/api/server.ts" },
    { "source": "/assets/(.*)", "destination": "/assets/$1" },
    { "source": "/((?!api|auth|assets|.*\\.).*)", "destination": "/index.html" }
  ],
  "cleanUrls": true
}
