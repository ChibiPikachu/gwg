{
  "version": 2,
  "functions": {
    "server.ts": {
      "includeFiles": "hltb_bridge.py"
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/server.ts" },
    { "source": "/auth/:path*", "destination": "/server.ts" },
    { "source": "/((?!api|auth|assets|favicon.ico).*)", "destination": "/index.html" }
  ],
  "cleanUrls": true
}
