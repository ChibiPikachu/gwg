{
    "compilerOptions": {
        "target": "ES2022",
        "experimentalDecorators": true,
        "useDefineForClassFields": false,
        "module": "ESNext",
        "lib": [
            "ES2022",
            "DOM",
            "DOM.Iterable"
        ],
        "skipLibCheck": true,
        "moduleResolution": "bundler",
        "jsx": "react-jsx",
        "types": [
            "vite/client",
            "node"
        ],
        "baseUrl": ".",
        "paths": {
            "@/*": [
                "src/*"
            ]
        },
        ,
        "exclude": [
            "node_modules",
            "api",
            "hltb_bridge.py"
        ],
        "allowImportingTsExtensions": true,
        "noEmit": true
    }
}